
<% layout("/layouts/boilerplate") %>

    <%= success %> 

    <h3>All listings</h3>

    <!-- <form method ="GET" action="/listings/new">

        <button> Add New Listing</button>
        
    </form> -->

    <div class="row row-cols-lg-3 row-cols-mid-2 row-cols-sm-1" >


    
<% for(let listing of allListings){  %>
  <a href="/listings/<%=listing._id %>" class="listing-link">
<div class="card listing-card" style="width: 20rem;">
  <img src=<%= listing.image.url %> class="card-img-top" alt="listing img" style="height :20rem" >

  
  
  <div class="card-img-overlay"> </div>



  <div class="card-body">
    <p class="card-text"> 
        
      <b>  <%= listing.title %></p></b>
        &#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>
  </div>
</div>
  </a>
 <%  } %>

 </div>

  

