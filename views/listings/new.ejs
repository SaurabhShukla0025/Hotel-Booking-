<% layout("/layouts/boilerplate") %>

<div class="row" >

    <div class="col-8 offset-2"></div>
<body>

    <h3>
        Add New Listings
    </h3>

    <form method="POST"  action ="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label" for="title">Title </label>
        <input placeholder=" Enter  Title" name="listing[title]" class="form-control" required>
        <div class="valid-feedback"> Please Enter Valid Title</div>

        </div>

        <div class="mb-3">

         <label class="form-label" for="description">Desription </label>
         <textarea  name="listing[description]" class="form-control" required> </textarea>
          <div class="invalid-feedback"> Please Enter sort Description</div>
        </div>


        <div class="mb-3">
            <label class="form-image" for="image" > Listing image</label>
            <input name="listing[image][url]"  placeholder="enter your image link" class="form-control" >
        </div>

        <div class="mb-3">
            <label class="form-image" for="image" >Uplode Your Listing image</label>
            <input name="listing[image][url]" type="file"  class="form-control" required >
        </div>



        <div class="row">

         <div class="mb-3 col-md-4">
         <label class="form-label" for="price">Price </label>
            <input placeholder=" Enter Price " name="listing[price]" class="form-control" required>
             <div class="invalid-feedback"> Please Enter Valid Price</div>


         </div >


     <div class="mb-3 col-md-8">
       <label class="form-label" for="country">Country </label>
      <input placeholder=" Enter  country" name="listing[country]" class="form-control" required>

       <div class="invalid-feedback"> Please Enter  Country  </div>
           </div>

        </div>
          
          <div class="mb-3">
         <label class="form-label" for="location">Location </label>
         <input placeholder=" Enter Location " name="listing[location]" class="form-control" required>
          <div class="invalid-feedback"> Please Enter  Location</div>
          </div>

        
          
          
           <br><br>
            

            <button class="btn btn-dark add-btn">Add</button>
    </form>
      <br>
    
</body>
</div>
</div>